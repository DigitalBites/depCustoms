# SHARED
ALL_IN_ONE_DATABASE_URL=postgresql://postgres:your_pw@db:5432/postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=your_pw

# SERVICE CADDY
ALL_IN_ONE_CADDY_HTTP_PORT=80
ALL_IN_ONE_CADDY_HTTPS_HOST=IPAddressOrHostName
ALL_IN_ONE_CADDY_HTTPS_PORT=8443
ALL_IN_ONE_PROXY_HTTPS_PORT=8442
ALL_IN_ONE_PUBLIC_ORIGIN=https://IPAddressOrHostName:8443
PROXY_PUBLIC_BASE_URL=https://IPAddressOrHostName:8442
PROXY_ALLOWED_PUBLIC_BASE_URLS=https://IPAddressOrHostName:8442

# SERVICE AUTH
AUTH_URL=https://IPAddressOrHostName:8443
GOTRUE_SITE_URL=https://IPAddressOrHostName:8443
GOTRUE_API_EXTERNAL_URL=https://IPAddressOrHostName:8443
GOTRUE_URI_ALLOW_LIST=https://IPAddressOrHostName:8443
ALL_IN_ONE_GOTRUE_DB_SCHEMA=auth
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_JWT_SECRET=
GOTRUE_JWT_KEYS=
GOTRUE_ANON_KEY=
GOTRUE_SERVICE_ROLE_KEY=
GOTRUE_HOOK_SECRET=
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_ENABLED=true
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_URI=http://host.docker.internal:3000/internal/auth/token-hook
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_SECRETS=
GOTRUE_JWT_EXP=3600
GOTRUE_SESSIONS_INACTIVITY_TIMEOUT=2h
GOTRUE_SESSIONS_TIMEBOX=10h
GOTRUE_OAUTH_SERVER_ENABLED=true
GOTRUE_OAUTH_SERVER_ALLOW_DYNAMIC_REGISTRATION=true
GOTRUE_OAUTH_SERVER_AUTHORIZATION_PATH=/auth/oauth/authorize
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_MAILER_URLPATHS_INVITE=/auth/v1/verify
GOTRUE_MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
GOTRUE_MAILER_URLPATHS_RECOVERY=/auth/v1/verify
GOTRUE_MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
GOTRUE_SMTP_ADMIN_EMAIL=admin@example.com
GOTRUE_SMTP_HOST=supabase-mail
GOTRUE_SMTP_PORT=2500
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=Customs

# SERVICE API
API_PORT=3000
API_LOG_LEVEL=debug
BOOTSTRAP_MODE=bundled
BOOTSTRAP_FIRST_USER_SECRET=
BOOTSTRAP_SETUP_GOTRUE=true
BOOTSTRAP_SETUP_FIRST_TENANT=true
BOOTSTRAP_SETUP_FIRST_PROXY=true
BOOTSTRAP_SETUP_DEFAULT_POLICIES=true
INTERNAL_SERVICE_JWT_PRIVATE_JWK=
INTERNAL_SERVICE_JWT_KEY_ID=internal-service-1
BOOTSTRAP_PROXY_ID=
BOOTSTRAP_PROXY_KEY=

# SERVICE DASHBOARD
DASHBOARD_PORT=3001
AUTH_PROXY_ENABLED=false
DASHBOARD_API_PROXY_ENABLED=false

# SERVICE PROXY
PROXY_LOG_LEVEL=info
PROXY_ID=
PROXY_CONTROL_PLANE_SECRET=
PROXY_REDACT_CLIENT_IP=false
PROXY_TRUSTED_PROXY_CIDRS=172.31.0.0/16
