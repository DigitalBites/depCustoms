# Postgres / pgvector
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customs
INTELLIGENCE_DB_SCHEMA=intel

# Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small

# LLM judge
JUDGE_MODEL=openai/gpt-4o-mini

# Runtime
INTELLIGENCE_PORT=8001
LOG_LEVEL=info
INTELLIGENCE_INTERNAL_JWKS_URL=http://localhost:3000/.well-known/internal-service-jwks.json
INTELLIGENCE_INTERNAL_JWT_AUDIENCE=customs-intelligence-rpc

# Typosquat thresholds
SIMILARITY_LOW_THRESHOLD=0.85
SIMILARITY_HIGH_THRESHOLD=0.97
SEARCH_TOP_K=5

# Local development mode. When true, the service uses deterministic stub
# embeddings and judge responses so the HTTP contract can be exercised before
# API keys and vector data are configured.
INTELLIGENCE_STUB_MODE=true
