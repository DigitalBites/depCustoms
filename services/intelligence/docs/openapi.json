{
  "components": {
    "schemas": {
      "CheckMetadata": {
        "properties": {
          "adjacent_name_found_in_corpus": {
            "title": "Adjacent Name Found In Corpus",
            "type": "boolean"
          },
          "candidate_score_final": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Candidate Score Final"
          },
          "candidate_source_rank": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Candidate Source Rank"
          },
          "candidate_trust": {
            "anyOf": [
              {
                "enum": [
                  "low",
                  "medium",
                  "high"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Candidate Trust"
          },
          "judge_cache_hit": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Judge Cache Hit"
          },
          "lexical_similarity_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lexical Similarity Score"
          },
          "similarity_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Similarity Score"
          },
          "stage_timings_ms": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "integer"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stage Timings Ms"
          }
        },
        "required": [
          "similarity_score",
          "lexical_similarity_score",
          "candidate_source_rank",
          "candidate_score_final",
          "candidate_trust",
          "adjacent_name_found_in_corpus"
        ],
        "title": "CheckMetadata",
        "type": "object"
      },
      "CheckRequest": {
        "properties": {
          "description": {
            "anyOf": [
              {
                "maxLength": 4096,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "ecosystem": {
            "enum": [
              "npm",
              "pypi"
            ],
            "title": "Ecosystem",
            "type": "string"
          },
          "package": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Package",
            "type": "string"
          }
        },
        "required": [
          "ecosystem",
          "package"
        ],
        "title": "CheckRequest",
        "type": "object"
      },
      "CheckResponse": {
        "properties": {
          "confidence": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "title": "Confidence",
            "type": "string"
          },
          "is_suspicious": {
            "title": "Is Suspicious",
            "type": "boolean"
          },
          "latency_ms": {
            "title": "Latency Ms",
            "type": "integer"
          },
          "llm_verdict": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Llm Verdict"
          },
          "match_quality": {
            "enum": [
              "weak",
              "ambiguous",
              "strong"
            ],
            "title": "Match Quality",
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/CheckMetadata"
          },
          "nearest_match": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Nearest Match"
          },
          "recommended_action": {
            "enum": [
              "allow",
              "review",
              "block"
            ],
            "title": "Recommended Action",
            "type": "string"
          },
          "source": {
            "enum": [
              "stub",
              "vector_search"
            ],
            "title": "Source",
            "type": "string"
          }
        },
        "required": [
          "is_suspicious",
          "nearest_match",
          "match_quality",
          "recommended_action",
          "llm_verdict",
          "confidence",
          "latency_ms",
          "source",
          "metadata"
        ],
        "title": "CheckResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "SeedRequest": {
        "properties": {
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          },
          "ecosystem": {
            "enum": [
              "npm",
              "pypi"
            ],
            "title": "Ecosystem",
            "type": "string"
          },
          "limit": {
            "default": 500,
            "maximum": 10000.0,
            "minimum": 1.0,
            "title": "Limit",
            "type": "integer"
          }
        },
        "required": [
          "ecosystem"
        ],
        "title": "SeedRequest",
        "type": "object"
      },
      "SeedResponse": {
        "properties": {
          "ecosystem": {
            "enum": [
              "npm",
              "pypi"
            ],
            "title": "Ecosystem",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "processed_count": {
            "title": "Processed Count",
            "type": "integer"
          },
          "queued": {
            "title": "Queued",
            "type": "boolean"
          },
          "source": {
            "const": "stub",
            "title": "Source",
            "type": "string"
          }
        },
        "required": [
          "ecosystem",
          "queued",
          "processed_count",
          "source",
          "message"
        ],
        "title": "SeedResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Customs Intelligence Service",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/check": {
      "post": {
        "operationId": "check_package_check_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Check Package"
      }
    },
    "/healthz": {
      "get": {
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Healthz Healthz Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Healthz"
      }
    },
    "/seed": {
      "post": {
        "operationId": "seed_seed_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SeedRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Seed"
      }
    }
  }
}
