# Runtime logging
# Default: LOG_LEVEL=info
LOG_LEVEL=debug

# Server
# Default: PROXY_PORT=8080
PROXY_PORT=8080
PROXY_PUBLIC_BASE_URL=http://localhost:8080
# Default: PROXY_NPM_METADATA_MAX_BYTES=33554432
PROXY_NPM_METADATA_MAX_BYTES=33554432
# Default: PROXY_NPM_AUDIT_MAX_BODY_BYTES=5242880
# Caps npm security audit passthrough request bodies before proxying upstream.
PROXY_NPM_AUDIT_MAX_BODY_BYTES=5242880
# Default: PROXY_PYPI_METADATA_MAX_BYTES=2097152
PROXY_PYPI_METADATA_MAX_BYTES=2097152

# Identity / control plane
PROXY_ID=
PROXY_CONTROL_PLANE_URL=http://localhost:3000
PROXY_CONTROL_PLANE_SECRET=

# Privacy / forwarded IP handling
# Default: PROXY_REDACT_CLIENT_IP=false
PROXY_REDACT_CLIENT_IP=false
# Optional comma-separated CIDRs.
PROXY_TRUSTED_PROXY_CIDRS=
# Example: PROXY_TRUSTED_PROXY_CIDRS=127.0.0.1/32,10.0.0.0/8

# Decision cache
# Default: PROXY_CACHE_TTL_SECONDS=300
PROXY_CACHE_TTL_SECONDS=300
# Default: PROXY_PACKAGE_METADATA_CACHE_TTL_SECONDS=300
PROXY_PACKAGE_METADATA_CACHE_TTL_SECONDS=300
# Default: PROXY_PACKAGE_METADATA_SIGNAL_DEDUPE_TTL_SECONDS=300
PROXY_PACKAGE_METADATA_SIGNAL_DEDUPE_TTL_SECONDS=300
# Default: PROXY_METADATA_CACHE_STATS_REPORT_INTERVAL_SECONDS=60
PROXY_METADATA_CACHE_STATS_REPORT_INTERVAL_SECONDS=60

# Contributor metadata cache
# Default: PROXY_CONNECTOR_CONTRIBUTOR_ENABLED=true
PROXY_CONNECTOR_CONTRIBUTOR_ENABLED=true
# Default: PROXY_CONNECTOR_CONTRIBUTOR_PREFETCH_WINDOW_DAYS=90
PROXY_CONNECTOR_CONTRIBUTOR_PREFETCH_WINDOW_DAYS=90
# Default: PROXY_CONTRIBUTOR_METADATA_CACHE_PATH=./data/contributor_metadata_cache.json
PROXY_CONTRIBUTOR_METADATA_CACHE_PATH=./data/contributor_metadata_cache.json
# Default: PROXY_CONTRIBUTOR_METADATA_VERSION_CAP=250
PROXY_CONTRIBUTOR_METADATA_VERSION_CAP=250
# Default: PROXY_CONTRIBUTOR_METADATA_COLD_DAYS=45
PROXY_CONTRIBUTOR_METADATA_COLD_DAYS=45

# WAL / delivery
# Default: PROXY_FLUSH_INTERVAL_SECONDS=10
PROXY_FLUSH_INTERVAL_SECONDS=10
# Default: PROXY_FLUSH_MAX_EVENTS=100
PROXY_FLUSH_MAX_EVENTS=100
# Default: PROXY_EVENT_RETENTION_HOURS=48
PROXY_EVENT_RETENTION_HOURS=48
# Default: PROXY_WAL_PATH=./data/events.ndjson
PROXY_WAL_PATH=./data/events.ndjson
# Default: PROXY_CHECKPOINT_PATH=./data/events.checkpoint
PROXY_CHECKPOINT_PATH=./data/events.checkpoint
