# Runtime environment
# Default: ENVIRONMENT=development
ENVIRONMENT=development
# Default: LOG_LEVEL=info
LOG_LEVEL=debug

# Server
# Default: PORT=3000
PORT=3000
# Default: API_REQUEST_BODY_LIMIT_BYTES=1048576
API_REQUEST_BODY_LIMIT_BYTES=1048576
# Default: API_RECORD_USAGE_MAX_EVENTS=1000
API_RECORD_USAGE_MAX_EVENTS=1000

# Internal proxy runtime JWTs issued by the API after bootstrap auth.
# The proxy does NOT read this value; it only sends PROXY_ID + PROXY_CONTROL_PLANE_SECRET
# to the token exchange endpoint and then uses the returned bearer token.
# This value is required by the API today. In bundled/bootstrap mode we may
# generate and persist it, but there is no code-level default fallback.
PROXY_JWT_SECRET=dev-proxy-jwt-secret-not-for-production
# Default: PROXY_JWT_TTL_SECONDS=900
PROXY_JWT_TTL_SECONDS=900

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customs

# GoTrue / auth proxy
AUTH_URL=http://localhost:3000
# Default: AUTH_PROXY_ENABLED=true
AUTH_PROXY_ENABLED=true
GOTRUE_URL=http://localhost:9999
GOTRUE_ANON_KEY=
GOTRUE_SERVICE_ROLE_KEY=
GOTRUE_HOOK_SECRET=
# Default: GOTRUE_REQUEST_TIMEOUT_MS=5000
GOTRUE_REQUEST_TIMEOUT_MS=5000

# Browser CORS allowlist (comma-separated)
# Default: API_CORS_ORIGIN=http://localhost:3001
API_CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001

# ---------------------------------------------------------------------------
# Package intelligence connectors
# ---------------------------------------------------------------------------

# OSV connector
# Default: CONNECTOR_OSV_ENABLED=true
CONNECTOR_OSV_ENABLED=true
# Default: OSV_API_URL=https://api.osv.dev
OSV_API_URL=https://api.osv.dev
# Default: CONNECTOR_OSV_CACHE_TTL_SECONDS=3600
CONNECTOR_OSV_CACHE_TTL_SECONDS=3600
# Default: CONNECTOR_OSV_RESPONSE_TIMEOUT_MS=2000
CONNECTOR_OSV_RESPONSE_TIMEOUT_MS=2000
# Default: CONNECTOR_OSV_BACKGROUND_TIMEOUT_MS=30000
CONNECTOR_OSV_BACKGROUND_TIMEOUT_MS=30000

# Contributor risk connector
# Default: CONNECTOR_CONTRIBUTOR_ENABLED=true
CONNECTOR_CONTRIBUTOR_ENABLED=true
# Default: CONNECTOR_CONTRIBUTOR_CACHE_TTL_SECONDS=3600
CONNECTOR_CONTRIBUTOR_CACHE_TTL_SECONDS=3600
# Default: CONNECTOR_CONTRIBUTOR_RESPONSE_TIMEOUT_MS=3000
CONNECTOR_CONTRIBUTOR_RESPONSE_TIMEOUT_MS=3000
# Optional development override for all contributor TTLs.
# Default: unset
# CONNECTOR_CONTRIBUTOR_CACHE_TTL_OVERRIDE_SECONDS=604800
