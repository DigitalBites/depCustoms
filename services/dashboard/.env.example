PORT=3001

# Auth (GoTrue via same-origin dev proxy)
#
# LOCAL DEV: set to the dashboard's own origin (e.g. http://localhost:3001).
# next.config.ts rewrites /auth/v1/* → API_INTERNAL_URL server-side, making
# auth requests same-origin and bypassing browser CORS restrictions entirely.
#
# PRODUCTION: set to your public API URL (e.g. https://api.yourdomain.com).
# The browser hits the API directly; CORS is handled by the API's
# API_CORS_ORIGIN setting. Do NOT point this at the dashboard origin in prod
# (the rewrite only applies when NEXT_PUBLIC_API_URL includes localhost:3001).
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_GOTRUE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd6OFkOT3oKZf4ub6qvWepBqQSfXGcK4

# In local dev, point this at the dashboard's own origin (port 3001) so
# the same-origin dev proxy can forward /v1/* to the API and avoid Safari
# cross-origin localhost issues.
# In production, set this to your actual API URL (e.g. https://api.yourdomain.com).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Enable the dashboard same-origin dev proxy for /v1/* and /auth/v1/*.
# Recommended for local dev when the browser talks to http://localhost:3001 and
# the dashboard forwards to API_INTERNAL_URL server-side. Set to false in
# deployments where the browser should call the API directly.
DASHBOARD_API_PROXY_ENABLED=true

# Server-side only — used by the same-origin dev proxy and SSE proxy route handlers
# to reach the API directly.
# In production, set to your internal API URL (e.g. http://api:8080).
API_INTERNAL_URL=http://localhost:3000
